# Database (required)
DATABASE_URL=postgres://pliq_user:your-password-here@localhost:5432/pliq_dev

# HTTP Server
HTTP_HOST=0.0.0.0
HTTP_PORT=3001

# gRPC
GRPC_PORT=50051
GRPC_AI_HOST=http://localhost:50052

# Auth (required)
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRY_HOURS=24

# World ID (required: WORLD_ID_APP_ID)
WORLD_ID_APP_ID=app_your-app-id
WORLD_ID_ACTION=pliq-verify
WORLD_ID_API_URL=https://developer.worldcoin.org/api/v2/verify

# CORS
CORS_ORIGINS=http://localhost:3000

# Rate Limiting
RATE_LIMIT_RPS=100

# Logging
LOG_LEVEL=info
LOG_FORMAT=pretty

# Unlink Privacy (optional)
UNLINK_API_KEY=
UNLINK_ENGINE_URL=https://staging-api.unlink.xyz

# Circle Payments (optional)
CIRCLE_API_KEY=

# WebSocket
WS_HEARTBEAT_INTERVAL_SECS=30
WS_MAX_MESSAGE_SIZE=65536

# WebRTC
STUN_SERVER=stun:stun.l.google.com:19302

# Platform
PLATFORM_FEE_BPS=100
